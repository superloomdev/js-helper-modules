# Dependencies
node_modules/
package-lock.json

# Personal dev workspace (lives at workspace root, never inside a repo)
__dev__/

# Legacy cleanup folder (never committed)
_cleanup/

# Work in progress (personal planning, never committed)
wip/

# Environment files (never commit secrets)
.env
.env.*

# Config with secrets
config/

# OS files
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride
._*

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build output
dist/
DIST/
build/

# npmrc files (never commit registry credentials anywhere)
**/.npmrc

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# SQLite artefacts (generated inside _test/ during testing)
**/_test/*.db
**/_test/*.sqlite
**/_test/*.sqlite3
**/_test/*.db-journal
**/_test/*.db-wal
**/_test/*.db-shm

# npm cache directory
.npm

# Serverless Framework cache
.serverless
