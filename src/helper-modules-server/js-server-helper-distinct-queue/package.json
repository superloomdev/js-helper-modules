{
  "name": "@superloomdev/js-server-helper-distinct-queue",
  "description": "Persistent, storage-agnostic last-write-wins coalescing queue keyed by tenant and resource. N rapid-fire writes collapse into at most one execution of the latest payload. Built-in stores for DynamoDB and MongoDB.",
  "version": "1.0.0",
  "main": "distinct-queue.js",
  "private": false,
  "license": "MIT",
  "author": {
    "name": "sj00"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "peerDependencies": {
    "helper-utils": "npm:@superloomdev/js-helper-utils@>=1.0.0",
    "helper-debug": "npm:@superloomdev/js-helper-debug@>=1.0.0",
    "helper-instance": "npm:@superloomdev/js-server-helper-instance@>=1.0.0"
  },
  "optionalPeerDependencies": {
    "helper-distinct-queue-store-dynamodb": "npm:@superloomdev/js-server-helper-distinct-queue-store-dynamodb@^1.0.0",
    "helper-distinct-queue-store-mongodb": "npm:@superloomdev/js-server-helper-distinct-queue-store-mongodb@^1.0.0"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "@eslint/js": "^10.0.1"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test _test/test.js"
  }
}
